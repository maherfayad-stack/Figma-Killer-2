{
  "name": "@ccs/sync-daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Node daemon: per-file-folder Vite orchestration, ws protocol server, chokidar FS watch, git checkpoint commits. P1 scope.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@ccs/ast-engine": "workspace:*",
    "@ccs/protocol": "workspace:*",
    "@ccs/tokens": "workspace:*",
    "@ccs/vite-plugin-source-uid": "workspace:*",
    "@ccs/bridge": "workspace:*",
    "chokidar": "catalog:",
    "simple-git": "catalog:",
    "vite": "catalog:",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
