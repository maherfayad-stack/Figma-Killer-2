{
  "name": "@ccs/canvas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "tldraw integration, FrameShape, selection overlay. P1 scope; P0 is a typed stub behind the abstraction (playbook §5.4).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p dev/tsconfig.json && tsc --noEmit -p e2e/tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "demo:daemon": "tsx dev/run-daemon.ts",
    "demo:harness": "vite dev --config dev/vite.config.ts",
    "demo:custom-engine": "vite dev --config dev/custom-engine-vite.config.ts"
  },
  "dependencies": {
    "@ccs/bridge": "workspace:*",
    "@ccs/protocol": "workspace:*",
    "html-to-image": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tldraw": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@ccs/sync-daemon": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
